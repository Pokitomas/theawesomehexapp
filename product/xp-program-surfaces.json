{
  "schema": "archie-public-workflow/v2",
  "product_model": "one-task-progressive-views",
  "root_surface": "one-request-router",
  "workflow": {
    "entry": "one rough human request",
    "automatic_routing": true,
    "routes": ["answer", "build", "explore", "research"],
    "shared_state": "one local task handed between views",
    "default_behavior": "choose the smallest workflow that can finish the request",
    "advanced_controls": "hidden until relevant"
  },
  "views": [
    { "id": "archie", "route": "/archie/", "human_label": "Answer", "job": "shape one request and reveal boundaries on demand" },
    { "id": "maker", "route": "/maker/", "human_label": "Build", "job": "authorize repository work and proof" },
    { "id": "founder", "route": "/founder/", "human_label": "Explore", "job": "open genuinely different directions before commitment" },
    { "id": "foundry", "route": "/foundry/", "human_label": "Research", "job": "preserve a full campaign while showing only distinct readable approaches" },
    { "id": "expo", "route": "/world-expo/", "human_label": "Results", "job": "show artifacts, evidence, failures, and portable exits" }
  ],
  "visual_rules": {
    "shared_shell": true,
    "primary_action_count": "one per view",
    "progressive_disclosure": true,
    "information_primitives": ["plain-language-request", "one-primary-action", "details", "status", "artifact", "receipt"],
    "forbidden": [
      "user-must-understand-internal-subsystems-before-starting",
      "duplicate-request-entry-across-views",
      "raw-schema-as-default-interface",
      "twenty-four-near-duplicate-candidate-cards",
      "generic-ai-saas-dashboard",
      "fake-runtime-state"
    ]
  },
  "mobile": {
    "model": "one readable task with optional detail drawers",
    "task_switching": "shared top navigation",
    "minimum_phone_target_css_px": 44
  },
  "accessibility": {
    "semantic_html": true,
    "keyboard_complete": true,
    "screen_reader_state": true,
    "zoom_reflow": "400-percent",
    "minimum_phone_target_css_px": 44,
    "reduced_motion": true,
    "forced_colors": true,
    "essential_text_in_images": false
  },
  "claim_boundary": "The shared workflow organizes intent and produces local packets. It does not claim model execution, training, repository mutation, deployment, or independent capability admission."
}

  "failure_contracts": [
    { "condition": "OPFS unavailable", "required_result": "survival.mirror.unavailable receipt" },
    { "condition": "OPFS write interruption", "required_result": "survival.mirror.failed receipt and no checkpoint" },
    { "condition": "save picker cancelled", "required_result": "cancelled with no false export receipt" },
    { "condition": "invalid Ark magic", "required_result": "NOT A SIDEWAYS ARK" },
    { "condition": "invalid Ark header", "required_result": "ARK HEADER IS INVALID" },
    { "condition": "unsupported Ark version", "required_result": "ARK VERSION IS NOT SUPPORTED" },
    { "condition": "duplicate hash during restore", "required_result": "skip duplicate and report count" },
    { "condition": "server projection in cache", "required_result": "exclude it from private Ark" }
  ],
  "open_gaps": [
    "restore needs an explicit rollback witness for transaction failure",
    "download-issued does not prove the file was retained",
    "large Ark creation currently materializes one Blob in memory",
    "real browser quota pressure still needs a browser-level witness"
  ]

  "same_origin_copy": "OPFS",
  "portable_copy": ".sideways Ark",
  "states": [
    { "id": "hot", "meaning": "browser-managed storage only", "portable": false },
    { "id": "pinned", "meaning": "persistent storage requested", "portable": false },
    { "id": "mirror", "meaning": "same-origin OPFS copy exists", "portable": false },
    { "id": "ark", "meaning": "browser download was requested", "portable": "not_proven" },
    { "id": "external", "meaning": "file-system save completed", "portable": true }

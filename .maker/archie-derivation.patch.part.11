+  console.log(JSON.stringify({ schema: report.schema, benchmark_digest: report.benchmark_digest, metrics: report.metrics, verdict: report.verdict, failures: report.rows.filter(row => !row.success) }, null, 2));
+  if (report.metrics.forbidden_rejection_rate < 1 || report.metrics.open_world_abstention_rate < 1 || report.metrics.compositional_replacement_rate < 0.5) process.exitCode = 1;
+}
+
+await main();

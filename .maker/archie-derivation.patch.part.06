+    intelligence_claim: 'bounded-composition-over-owned-typed-transformations',
+    not_a_generative_language_model: true,
+    dimensions: config.dimensions,
+    threshold: config.threshold,
+    minimum_grounding: config.minimum_grounding,
+    max_steps: config.max_steps,
+    max_expansions: config.max_expansions,
+    vector_encoding: 'signed-int8-q8-sparse',

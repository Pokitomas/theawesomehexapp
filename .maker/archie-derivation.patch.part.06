+  if (/\b(?:check ?point|snapshot|savepoint|backup|preserve|retain)\b/.test(source)) return 'preserve';
+  if (/\b(?:test|tests|testing|verify|verified|validate|validation|check|prove|proof|score|evaluate|recovery)\b/.test(source)) return 'verify';

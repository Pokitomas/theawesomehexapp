+      negative_examples: negatives.length,
+      metadata_records: knowledgeRecords.length,
+      concepts: graph.nodes.length,
+      relations: graph.edges.length,
+      sparse_matrix_entries: graph.sparse_relation_matrix_q8.length,
+      source_text_bytes: trainingTexts.reduce((sum, value) => sum + Buffer.byteLength(value), 0),
+      model_bytes_without_digest: 0,

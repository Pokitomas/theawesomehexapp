index 0000000..13ca025
--- /dev/null
+++ b/test-harness/archie-derivation-benchmark.mjs
@@ -0,0 +1,206 @@
+#!/usr/bin/env node
+import crypto from 'node:crypto';
+import fs from 'node:fs/promises';
+import path from 'node:path';
+import {
+  deriveArchiePlan,
+  derivationCompressionReceipt,
+  trainArchieDerivationGraph
+} from '../scripts/maker-archie-derivation.mjs';
+
+const FIXED_TIME = '2026-07-16T08:00:00.000Z';
+const sha = value => crypto.createHash('sha256').update(typeof value === 'string' ? value : JSON.stringify(value)).digest('hex');
+const tool = (name, action, abstraction = null) => ({ tool: name, action, ok: true, ...(abstraction ? { abstraction } : {}) });
+const positive = (id, instruction, tools) => ({

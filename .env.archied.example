# Copy to .env.archied. Never commit the real file.
# Generate each long raw access token independently, then store only its SHA-256 digest here:
#   node -e "const c=require('node:crypto'); console.log(c.createHash('sha256').update(process.argv[1]).digest('hex'))" 'replace-with-a-long-random-token'
ARCHIED_FOUNDER_TOKEN_SHA256=replace-with-64-lowercase-hex-characters
ARCHIED_DEVELOPER_TOKEN_SHA256=replace-with-a-different-64-lowercase-hex-digest

# Generate independent 32-byte session-signing and encryption keys:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
ARCHIED_SESSION_KEY=replace-with-32-byte-base64-key
ARCHIED_SECRET_KEY=replace-with-a-different-32-byte-base64-key

# Stable external identity. Use HTTPS outside an explicitly isolated local test.
ARCHIED_PUBLIC_URL=https://archie.example/

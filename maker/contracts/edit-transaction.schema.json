{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/edit-transaction.schema.json",
  "title": "Maker transactional edit receipt",
  "type": "object",
  "required": [
    "schema",
    "transaction_id",
    "base_sha",
    "branch",
    "transaction_digest",
    "preview_digest",
    "status",
    "attempt",
    "mutations",
    "diff_digest",
    "authority",
    "receipt_digest"
  ],
  "properties": {
    "schema": { "const": "sideways-maker-edit-receipt/v1" },
    "transaction_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "repository": { "type": ["string", "null"] },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "branch": { "type": "string", "minLength": 1 },
    "transaction_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "preview_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "enum": ["applied", "rolled_back", "rollback_failed", "cancelled"] },
    "attempt": { "type": "integer", "minimum": 1 },
    "mutations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mutation_id", "operation_id", "kind", "path", "before", "after", "status"],
        "properties": {
          "mutation_id": { "type": "string" },
          "operation_id": { "type": "string" },
          "kind": { "enum": ["create", "write", "replace", "delete", "move"] },
          "role": { "enum": ["primary", "source", "destination"] },
          "path": { "type": "string" },
          "before": { "type": "object" },
          "after": { "type": "object" },
          "status": { "enum": ["pending", "applying", "applied", "verified", "rolled_back"] },
          "rollback_status": { "type": ["string", "null"] },
          "error": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "backups": { "type": "object" },
    "diff_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "errors": { "type": "array" },
    "authority": {
      "type": "object",
      "required": ["merge", "deploy"],
      "properties": {
        "merge": { "const": "human" },
        "deploy": { "const": "human" }
      },
      "additionalProperties": false
    },
    "finished_at": { "type": "string", "format": "date-time" },
    "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}

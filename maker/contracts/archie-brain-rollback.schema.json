{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archie-brain-rollback/v1",
  "title": "Trainer-signed Archie brain rollback receipt",
  "type": "object",
  "required": ["schema", "rolled_back_at", "activation_receipt_digest", "from_package_digest", "to_package_digest", "reason", "trainer_key_id", "receipt_digest", "signature"],
  "properties": {
    "schema": {"const": "archie-brain-rollback/v1"},
    "rolled_back_at": {"type": "string"},
    "activation_receipt_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "from_package_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "to_package_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reason": {"type": "string", "minLength": 1},
    "trainer_key_id": {"type": "string", "minLength": 1},
    "receipt_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "signature": {"$ref": "archie-brain-signature/v1"}
  },
  "additionalProperties": false
}

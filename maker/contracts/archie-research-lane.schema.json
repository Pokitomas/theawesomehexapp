{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.invalid/contracts/archie-research-lane.schema.json",
  "title": "Archie research lane v1",
  "type": "object",
  "required": [
    "schema",
    "campaign_id",
    "campaign_digest",
    "prior_campaign_digest",
    "allocation_digest",
    "policy_version",
    "lane_id",
    "lane_name",
    "lane_kind",
    "credits",
    "task_families",
    "worker_policy",
    "budget",
    "stop_rules",
    "promotion_boundaries",
    "data_binding",
    "authority",
    "owner_preference_axis",
    "state",
    "claim_boundary",
    "manifest_digest"
  ],
  "properties": {
    "schema": { "const": "archie-research-lane/v1" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "campaign_digest": { "$ref": "#/$defs/digest" },
    "prior_campaign_digest": { "$ref": "#/$defs/digest" },
    "allocation_digest": { "$ref": "#/$defs/digest" },
    "policy_version": { "type": "string", "minLength": 1 },
    "lane_id": { "$ref": "#/$defs/identifier" },
    "lane_name": { "type": "string", "minLength": 1 },
    "lane_kind": { "enum": ["discovery", "independent-evaluation"] },
    "credits": { "type": "integer", "minimum": 1 },
    "task_families": { "$ref": "#/$defs/nonEmptyStrings" },
    "worker_policy": {
      "type": "object",
      "required": ["allowed_worker_kinds", "required_capabilities", "priority_inference_from_availability"],
      "properties": {
        "allowed_worker_kinds": { "$ref": "#/$defs/nonEmptyStrings" },
        "required_capabilities": { "$ref": "#/$defs/nonEmptyStrings" },
        "priority_inference_from_availability": { "const": false }
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": ["max_cost_usd_per_experiment", "required_replications"],
      "properties": {
        "max_cost_usd_per_experiment": { "type": "number", "minimum": 0 },
        "required_replications": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "stop_rules": { "type": "object", "minProperties": 1 },
    "promotion_boundaries": { "type": "object", "minProperties": 1 },
    "data_binding": {
      "type": "object",
      "required": ["pack_digest", "training_data_digest", "hidden_data_digest", "hidden_access"],
      "properties": {
        "pack_digest": { "$ref": "#/$defs/digest" },
        "training_data_digest": { "$ref": "#/$defs/digest" },
        "hidden_data_digest": { "$ref": "#/$defs/digest" },
        "hidden_access": { "enum": ["digest-bound-no-content-access", "independent-judge-only"] }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["production_write", "self_promotion", "maker_execution_required", "continuing_compute_requires_executable_artifact"],
      "properties": {
        "production_write": { "const": false },
        "self_promotion": { "const": false },
        "maker_execution_required": { "const": true },
        "continuing_compute_requires_executable_artifact": { "const": true }
      },
      "additionalProperties": false
    },
    "owner_preference_axis": {
      "type": "object",
      "required": ["separate_from_capability", "continuing_compute_weight"],
      "properties": {
        "separate_from_capability": { "const": true },
        "continuing_compute_weight": { "const": 0 }
      },
      "additionalProperties": false
    },
    "state": { "const": "materialized" },
    "claim_boundary": { "type": "string", "minLength": 1 },
    "manifest_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archie-brain-signature/v1",
  "title": "Archie Trainer Ed25519 signature",
  "type": "object",
  "required": ["schema", "algorithm", "key_id", "value"],
  "properties": {
    "schema": {"const": "archie-brain-signature/v1"},
    "algorithm": {"const": "Ed25519"},
    "key_id": {"type": "string", "minLength": 1},
    "value": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/model-router.schema.json",
  "title": "Maker model provider router",
  "oneOf": [
    { "$ref": "#/$defs/provider" },
    { "$ref": "#/$defs/task" },
    { "$ref": "#/$defs/routeReceipt" },
    { "$ref": "#/$defs/budget" },
    { "$ref": "#/$defs/health" }
  ],
  "$defs": {
    "source": { "enum": ["observed", "configured", "unknown"] },
    "evidence": {
      "type": "object",
      "required": ["value", "source"],
      "properties": { "value": {}, "source": { "$ref": "#/$defs/source" } },
      "additionalProperties": false
    },
    "provider": {
      "type": "object",
      "required": ["schema", "id", "display_name", "kind", "health", "availability", "admission", "capabilities", "cost", "reliability", "preferences", "endpoint_label", "native", "metadata", "native_admission", "selectable", "descriptor_digest"],
      "properties": {
        "schema": { "const": "sideways-maker-provider/v1" },
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "kind": { "enum": ["native_checkpoint", "github_models", "openai_compatible", "ollama", "anthropic_compatible", "configured"] },
        "health": { "enum": ["healthy", "degraded", "offline", "unknown"] },
        "availability": { "$ref": "#/$defs/evidence" },
        "admission": { "type": "string" },
        "capabilities": { "type": "object", "additionalProperties": { "$ref": "#/$defs/evidence" } },
        "cost": { "type": "object", "additionalProperties": { "$ref": "#/$defs/evidence" } },
        "reliability": { "type": "object" },
        "preferences": { "type": "object" },
        "endpoint_label": { "type": "string" },
        "native": { "type": ["object", "null"] },
        "metadata": { "type": "object" },
        "native_admission": { "type": "object", "required": ["admitted", "reason"] },
        "selectable": { "type": "boolean" },
        "descriptor_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": ["schema", "id", "type", "role", "required", "preferred", "context_tokens", "output_tokens", "latency", "privacy_minimum", "locality_preference", "region_preference", "max_cost_usd", "input_tokens", "operator_preference", "excluded_provider_ids", "require_independent_grader", "output_schema"],
      "properties": {
        "schema": { "const": "sideways-maker-model-task/v1" },
        "id": { "type": "string" },
        "type": { "enum": ["planning", "repository_mapping", "coding", "debugging", "review", "summarization", "browser_interpretation", "grading"] },
        "role": { "type": "string" },
        "required": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "preferred": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "context_tokens": { "type": "integer", "minimum": 1 },
        "output_tokens": { "type": "integer", "minimum": 1 },
        "latency": { "type": "string" },
        "privacy_minimum": { "enum": ["local", "private", "contractual", "provider", "unknown"] },
        "locality_preference": { "type": "string" },
        "region_preference": { "type": "string" },
        "max_cost_usd": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "operator_preference": { "type": "array", "items": { "type": "string" } },
        "excluded_provider_ids": { "type": "array", "items": { "type": "string" } },
        "require_independent_grader": { "type": "boolean" },
        "output_schema": { "type": ["object", "null"] }
      },
      "additionalProperties": false
    },
    "usage": {
      "type": "object",
      "required": ["requests", "input_tokens", "output_tokens", "cost_usd", "wall_time_ms", "source"],
      "properties": {
        "requests": { "type": "integer", "minimum": 1 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 },
        "wall_time_ms": { "type": "integer", "minimum": 0 },
        "source": { "enum": ["provider_reported", "estimated"] }
      },
      "additionalProperties": false
    },
    "routeReceipt": {
      "type": "object",
      "required": ["schema", "route_id", "task_id", "provider", "state_digest", "score", "attempt", "repairs", "usage", "output", "attempts", "budget", "finished_at", "receipt_digest"],
      "properties": {
        "schema": { "const": "sideways-maker-model-route-receipt/v1" },
        "route_id": { "type": "string" },
        "task_id": { "type": "string" },
        "provider": { "type": "object" },
        "state_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "score": { "type": "number" },
        "attempt": { "type": "integer", "minimum": 0 },
        "repairs": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/usage" },
        "output": {},
        "attempts": { "type": "array", "items": { "type": "object" } },
        "budget": { "$ref": "#/$defs/budget" },
        "finished_at": { "type": "string", "format": "date-time" },
        "receipt_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": ["schema", "limits", "usage", "tasks"],
      "properties": {
        "schema": { "const": "sideways-maker-model-budget/v1" },
        "limits": { "type": "object" },
        "usage": { "type": "object" },
        "tasks": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": false
    },
    "health": {
      "type": "object",
      "required": ["schema", "providers", "at", "receipt_digest"],
      "properties": {
        "schema": { "const": "sideways-maker-model-health/v1" },
        "providers": { "type": "array", "items": { "type": "object" } },
        "at": { "type": "string", "format": "date-time" },
        "receipt_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}

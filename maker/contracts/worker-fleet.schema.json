{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/worker-fleet.schema.json",
  "title": "Sideways Maker worker fleet",
  "oneOf": [
    { "$ref": "#/$defs/worker" },
    { "$ref": "#/$defs/task" },
    { "$ref": "#/$defs/attestation" },
    { "$ref": "#/$defs/healthReceipt" },
    { "$ref": "#/$defs/artifactReference" },
    { "$ref": "#/$defs/placement" },
    { "$ref": "#/$defs/runtimeProfile" },
    { "$ref": "#/$defs/workspace" },
    { "$ref": "#/$defs/lease" },
    { "$ref": "#/$defs/dispatch" },
    { "$ref": "#/$defs/execution" },
    { "$ref": "#/$defs/usage" },
    { "$ref": "#/$defs/event" },
    { "$ref": "#/$defs/snapshot" }
  ],
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "attestation": {
      "type": "object",
      "required": [
        "schema",
        "worker_id",
        "subject",
        "mode",
        "endpoint_digest",
        "issuer",
        "issued_at",
        "digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-worker-attestation/v1" },
        "worker_id": { "type": "string" },
        "subject": { "type": "string" },
        "mode": { "type": "string" },
        "endpoint_digest": { "$ref": "#/$defs/digest" },
        "issuer": { "type": "string" },
        "issued_at": { "type": "string" },
        "observed_at": { "type": "string" },
        "state": { "type": "string" },
        "digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": true
    },
    "healthReceipt": {
      "type": "object",
      "required": [
        "schema",
        "worker_id",
        "endpoint_digest",
        "state",
        "issuer",
        "observed_at",
        "digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-worker-health/v1" },
        "worker_id": { "type": "string" },
        "endpoint_digest": { "$ref": "#/$defs/digest" },
        "state": { "enum": ["healthy", "degraded", "offline", "unknown"] },
        "issuer": { "type": "string" },
        "observed_at": { "type": "string" },
        "issued_at": { "type": "string" },
        "subject": { "type": "string" },
        "mode": { "type": "string" },
        "digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": true
    },
    "worker": {
      "type": "object",
      "required": [
        "schema",
        "id",
        "display_name",
        "identity",
        "mode",
        "platform",
        "labels",
        "capabilities",
        "toolchains",
        "providers",
        "models",
        "network",
        "isolation",
        "resources",
        "concurrency",
        "endpoint",
        "region",
        "privacy",
        "cost",
        "latency_ms",
        "health",
        "operator_state",
        "reliability",
        "recovery",
        "operator_weight",
        "metadata",
        "observed_at",
        "descriptor_digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-worker/v1" },
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "identity": { "type": "object" },
        "mode": {
          "enum": [
            "github_actions",
            "self_hosted",
            "remote_http",
            "in_process",
            "local_control"
          ]
        },
        "platform": { "type": "object" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "toolchains": { "type": "array", "items": { "type": "string" } },
        "providers": { "type": "array", "items": { "type": "string" } },
        "models": { "type": "array", "items": { "type": "string" } },
        "network": { "type": "object" },
        "isolation": { "type": "object" },
        "resources": { "type": "object" },
        "concurrency": { "type": "object" },
        "endpoint": { "type": "object" },
        "region": { "type": "string" },
        "privacy": { "type": "string" },
        "cost": { "type": "object" },
        "latency_ms": { "type": ["integer", "null"] },
        "health": { "type": "object" },
        "operator_state": {
          "enum": ["active", "draining", "quarantined", "offline"]
        },
        "reliability": { "type": "object" },
        "recovery": { "type": "object" },
        "operator_weight": { "type": "number" },
        "metadata": { "type": "object" },
        "observed_at": { "type": "string" },
        "descriptor_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": [
        "schema",
        "id",
        "owner",
        "repository",
        "backend",
        "priority",
        "reservation",
        "created_at",
        "capabilities",
        "labels",
        "toolchains",
        "providers",
        "models",
        "modes",
        "platform",
        "network",
        "allowed_hosts",
        "isolation",
        "resources",
        "region",
        "locality",
        "privacy",
        "capacity",
        "dedicated_capacity",
        "recoverable",
        "max_latency_ms",
        "max_cost_usd",
        "allow_unverified",
        "allow_unknown_cost",
        "retry_lost",
        "max_attempts",
        "attempt",
        "state"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-task/v1" },
        "id": { "type": "string" },
        "owner": { "type": "string" },
        "repository": { "type": "string" },
        "backend": { "type": "string" },
        "priority": { "type": "number" },
        "reservation": { "enum": ["normal", "repair", "recovery"] },
        "created_at": { "type": "string" },
        "capabilities": { "type": "array" },
        "labels": { "type": "array" },
        "toolchains": { "type": "array" },
        "providers": { "type": "array" },
        "models": { "type": "array" },
        "modes": { "type": "array" },
        "platform": { "type": "object" },
        "network": { "type": "string" },
        "allowed_hosts": { "type": "array" },
        "isolation": { "type": "object" },
        "resources": { "type": "object" },
        "region": { "type": "string" },
        "locality": { "type": "string" },
        "privacy": { "type": "string" },
        "capacity": { "type": "string" },
        "dedicated_capacity": { "type": "boolean" },
        "recoverable": { "type": "boolean" },
        "max_latency_ms": { "type": "number" },
        "max_cost_usd": { "type": "number" },
        "allow_unverified": { "type": "boolean" },
        "allow_unknown_cost": { "type": "boolean" },
        "retry_lost": { "type": "boolean" },
        "max_attempts": { "type": "integer" },
        "attempt": { "type": "integer" },
        "state": { "type": "object" }
      },
      "additionalProperties": false
    },
    "artifactReference": {
      "type": "object",
      "required": [
        "schema",
        "kind",
        "name",
        "uri",
        "digest",
        "size_bytes",
        "retention",
        "provenance",
        "workspace_id"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-artifact-reference/v1" },
        "kind": { "enum": ["artifact", "log"] },
        "name": { "type": "string" },
        "uri": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "retention": { "type": "string" },
        "provenance": { "type": "string" },
        "workspace_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "workspace": {
      "type": "object",
      "required": ["schema", "workspace_id", "ephemeral", "isolation"],
      "properties": {
        "schema": { "const": "sideways-maker-workspace-placement/v1" },
        "workspace_id": { "type": "string" },
        "ephemeral": { "type": "boolean" },
        "isolation": { "enum": ["sandbox", "container", "process"] }
      },
      "additionalProperties": false
    },
    "runtimeProfile": {
      "type": "object",
      "required": [
        "schema",
        "runtime_id",
        "display_name",
        "status",
        "intelligence",
        "endpoint",
        "planning",
        "execution",
        "authority",
        "presentation",
        "observed_at"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-runtime-profile/v1" },
        "runtime_id": { "type": "string" },
        "display_name": { "type": "string" },
        "status": { "enum": ["healthy", "degraded", "offline", "unknown"] },
        "intelligence": { "type": "object" },
        "endpoint": { "type": "object" },
        "planning": { "type": "object" },
        "execution": { "type": "object" },
        "authority": { "type": "object" },
        "presentation": { "type": "object" },
        "observed_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "required": [
        "schema",
        "placement_id",
        "task_id",
        "worker_id",
        "worker_mode",
        "reservation",
        "score",
        "estimated_cost_usd",
        "worker_digest",
        "task_digest",
        "endpoint",
        "workspace",
        "considered",
        "placed_at",
        "runtime_profile",
        "receipt_digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-placement/v1" },
        "placement_id": { "type": "string" },
        "task_id": { "type": "string" },
        "worker_id": { "type": "string" },
        "worker_mode": { "type": "string" },
        "reservation": { "type": "string" },
        "score": { "type": "number" },
        "estimated_cost_usd": { "type": ["number", "null"] },
        "worker_digest": { "type": "string" },
        "task_digest": { "type": "string" },
        "endpoint": { "type": "object" },
        "workspace": { "$ref": "#/$defs/workspace" },
        "considered": { "type": "array" },
        "placed_at": { "type": "string" },
        "runtime_profile": { "$ref": "#/$defs/runtimeProfile" },
        "receipt_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "lease": {
      "type": "object",
      "required": [
        "schema",
        "lease_id",
        "task_id",
        "worker_id",
        "token",
        "fence",
        "claimed_at",
        "expires_at",
        "digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-worker-lease/v1" },
        "lease_id": { "type": "string" },
        "task_id": { "type": "string" },
        "worker_id": { "type": "string" },
        "token": { "type": "string" },
        "fence": { "type": "integer", "minimum": 1 },
        "claimed_at": { "type": "string" },
        "expires_at": { "type": "string" },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "dispatch": {
      "type": "object",
      "required": ["schema", "mode", "ok", "started_at", "finished_at"],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-dispatch/v1" },
        "mode": { "type": "string" },
        "ok": { "type": "boolean" },
        "output": {},
        "started_at": { "type": "string" },
        "finished_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "usage": {
      "type": "object",
      "required": [
        "schema",
        "task_id",
        "worker_id",
        "cost_usd",
        "duration_ms",
        "references",
        "detail"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-usage/v1" },
        "task_id": { "type": "string" },
        "worker_id": { "type": "string" },
        "cost_usd": { "type": "number" },
        "duration_ms": { "type": "integer" },
        "references": { "type": "object" },
        "detail": { "type": "object" }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "schema",
        "task",
        "placement",
        "lease",
        "state",
        "revision",
        "started_at",
        "updated_at",
        "result",
        "error",
        "dispatch"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-execution/v1" },
        "task": { "$ref": "#/$defs/task" },
        "placement": { "$ref": "#/$defs/placement" },
        "lease": { "$ref": "#/$defs/lease" },
        "state": {
          "enum": [
            "dispatching",
            "running",
            "dispatch_failed",
            "completed",
            "failed",
            "cancelled",
            "lost"
          ]
        },
        "revision": { "type": "integer" },
        "started_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "result": { "type": ["object", "null"] },
        "error": { "type": ["object", "null"] },
        "dispatch": { "type": ["object", "null"] }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["schema", "sequence", "event_id", "type", "at", "detail"],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-event/v1" },
        "sequence": { "type": "integer" },
        "event_id": { "type": "string" },
        "type": { "type": "string" },
        "at": { "type": "string" },
        "detail": { "type": "object" }
      },
      "additionalProperties": false
    },
    "snapshot": {
      "type": "object",
      "required": [
        "schema",
        "workers",
        "queue",
        "executions",
        "quotas",
        "usage",
        "adapters",
        "events",
        "observed_at",
        "snapshot_digest"
      ],
      "properties": {
        "schema": { "const": "sideways-maker-fleet-snapshot/v1" },
        "workers": { "type": "array", "items": { "$ref": "#/$defs/worker" } },
        "queue": { "type": "array" },
        "executions": {
          "type": "array",
          "items": { "$ref": "#/$defs/execution" }
        },
        "quotas": { "type": "object" },
        "usage": { "type": "array" },
        "adapters": { "type": "array" },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
        "observed_at": { "type": "string" },
        "snapshot_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}

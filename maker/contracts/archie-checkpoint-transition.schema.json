{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.invalid/contracts/archie-checkpoint-transition.schema.json",
  "title": "Archie checkpoint transition receipt v1",
  "type": "object",
  "required": [
    "schema",
    "observed_at",
    "payload",
    "receipt_digest"
  ],
  "properties": {
    "schema": {
      "const": "archie-checkpoint-transition-receipt/v1"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "receipt_digest": {
      "$ref": "#/$defs/digest"
    },
    "payload": {
      "type": "object",
      "required": [
        "parent",
        "candidate",
        "lineage",
        "constraints"
      ],
      "properties": {
        "parent": {
          "$ref": "#/$defs/checkpoint"
        },
        "candidate": {
          "allOf": [
            {
              "$ref": "#/$defs/checkpoint"
            },
            {
              "type": "object",
              "required": [
                "exact_download_bytes",
                "exact_installed_bytes"
              ]
            }
          ]
        },
        "lineage": {
          "type": "object",
          "required": [
            "schema",
            "parent",
            "candidate",
            "training_data_digest",
            "trajectory_digest",
            "training_config_digest",
            "optimizer_digest",
            "authority_receipt_digest",
            "evaluation_receipt_digest",
            "seed",
            "teacher_ids",
            "rejected_checkpoint_digests"
          ],
          "properties": {
            "schema": {
              "const": "archie-checkpoint-lineage/v1"
            },
            "training_data_digest": {
              "$ref": "#/$defs/digest"
            },
            "trajectory_digest": {
              "$ref": "#/$defs/digest"
            },
            "training_config_digest": {
              "$ref": "#/$defs/digest"
            },
            "optimizer_digest": {
              "$ref": "#/$defs/digest"
            },
            "authority_receipt_digest": {
              "$ref": "#/$defs/digest"
            },
            "evaluation_receipt_digest": {
              "$ref": "#/$defs/digest"
            },
            "seed": {
              "type": "integer",
              "minimum": 0
            },
            "teacher_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "rejected_checkpoint_digests": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/digest"
              }
            }
          },
          "additionalProperties": true
        },
        "constraints": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "model_ref",
        "manifest_digest",
        "artifact_digest",
        "immutable_digest",
        "mutable_digest"
      ],
      "properties": {
        "model_ref": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}@[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
        },
        "manifest_digest": {
          "$ref": "#/$defs/digest"
        },
        "artifact_digest": {
          "$ref": "#/$defs/digest"
        },
        "immutable_digest": {
          "$ref": "#/$defs/digest"
        },
        "mutable_digest": {
          "$ref": "#/$defs/digest"
        },
        "mutable_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "benchmark_report_digest": {
          "$ref": "#/$defs/digest"
        },
        "exact_download_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "exact_installed_bytes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

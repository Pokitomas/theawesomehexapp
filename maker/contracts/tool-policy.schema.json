{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/tool-policy.schema.json",
  "title": "Maker bounded tool broker receipt",
  "type": "object",
  "required": ["schema", "status", "lease", "event_count", "terminal_digest", "events", "receipt_digest"],
  "properties": {
    "schema": { "const": "sideways-maker-tool-receipt/v1" },
    "status": { "enum": ["open", "cancelled", "closed"] },
    "lease": {
      "type": "object",
      "required": ["schema", "base_sha", "branch", "writer_count", "owned_paths", "authority", "lease_digest"],
      "properties": {
        "schema": { "const": "sideways-maker-tool-lease/v1" },
        "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "branch": { "type": "string" },
        "writer_count": { "const": 1 },
        "owned_paths": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "authority": {
          "type": "object",
          "required": ["merge", "deploy"],
          "properties": { "merge": { "const": "human" }, "deploy": { "const": "human" } },
          "additionalProperties": false
        },
        "lease_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "artifacts": { "type": "object" },
    "event_count": { "type": "integer", "minimum": 1 },
    "terminal_digest": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "events": { "type": "array", "items": { "type": "object" } },
    "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": true
}

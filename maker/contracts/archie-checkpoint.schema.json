{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/archie-checkpoint.schema.json",
  "title": "Archie learned-state contract and checkpoint",
  "oneOf": [
    { "$ref": "#/$defs/stateContract" },
    { "$ref": "#/$defs/checkpoint" },
    { "$ref": "#/$defs/compatibility" }
  ],
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableDigest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "gitOid": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" },
    "mutable": {
      "type": "object",
      "properties": {
        "parameters_digest": { "$ref": "#/$defs/nullableDigest" },
        "sparse_state_digest": { "$ref": "#/$defs/nullableDigest" },
        "graph_state_digest": { "$ref": "#/$defs/nullableDigest" },
        "routing_weights_digest": { "$ref": "#/$defs/nullableDigest" },
        "action_transition_digest": { "$ref": "#/$defs/nullableDigest" },
        "uncertainty_calibration_digest": { "$ref": "#/$defs/nullableDigest" },
        "negative_lessons_digest": { "$ref": "#/$defs/nullableDigest" },
        "episodic_memory_digest": { "$ref": "#/$defs/nullableDigest" },
        "retrieval_index_digest": { "$ref": "#/$defs/nullableDigest" }
      },
      "additionalProperties": false
    },
    "immutable": {
      "type": "object",
      "required": [
        "runtime_abi",
        "architecture",
        "architecture_config",
        "axioms",
        "authority",
        "state_schema",
        "allowed_learning_operations"
      ],
      "properties": {
        "runtime_abi": { "const": "archie-runtime/v1" },
        "architecture": { "type": "string", "minLength": 1 },
        "architecture_config": { "type": "object" },
        "axioms": { "type": "object" },
        "authority": { "type": "object" },
        "state_schema": { "type": "string", "minLength": 1 },
        "allowed_learning_operations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "stateContract": {
      "type": "object",
      "required": [
        "schema",
        "immutable",
        "mutable",
        "immutable_digest",
        "mutable_digest",
        "mutable_regions",
        "state_contract_digest"
      ],
      "properties": {
        "schema": { "const": "archie-state-contract/v1" },
        "immutable": { "$ref": "#/$defs/immutable" },
        "mutable": { "$ref": "#/$defs/mutable" },
        "immutable_digest": { "$ref": "#/$defs/digest" },
        "mutable_digest": { "$ref": "#/$defs/digest" },
        "mutable_regions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "state_contract_digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "training": {
      "type": "object",
      "required": [
        "code_commit",
        "dataset_digests",
        "trajectory_batch_digests",
        "teacher_ids",
        "teacher_model_ids",
        "seed",
        "optimizer",
        "config"
      ],
      "properties": {
        "code_commit": { "$ref": "#/$defs/gitOid" },
        "dataset_digests": { "type": "array", "items": { "$ref": "#/$defs/digest" }, "uniqueItems": true },
        "trajectory_batch_digests": { "type": "array", "items": { "$ref": "#/$defs/digest" }, "uniqueItems": true },
        "teacher_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "teacher_model_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "seed": { "type": ["integer", "null"] },
        "optimizer": { "type": "object" },
        "config": { "type": "object" }
      },
      "additionalProperties": false
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "schema",
        "model_id",
        "version",
        "manifest_digest",
        "runtime_abi",
        "immutable_digest",
        "mutable",
        "mutable_digest",
        "training",
        "benchmark_receipt_digests",
        "rejected",
        "rejection_reasons",
        "checkpoint_digest"
      ],
      "properties": {
        "schema": { "const": "archie-checkpoint/v1" },
        "model_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "manifest_digest": { "$ref": "#/$defs/digest" },
        "runtime_abi": { "const": "archie-runtime/v1" },
        "immutable_digest": { "$ref": "#/$defs/digest" },
        "mutable": { "$ref": "#/$defs/mutable" },
        "mutable_digest": { "$ref": "#/$defs/digest" },
        "parent_checkpoint_digest": { "$ref": "#/$defs/nullableDigest" },
        "training": { "$ref": "#/$defs/training" },
        "benchmark_receipt_digests": { "type": "array", "items": { "$ref": "#/$defs/digest" }, "uniqueItems": true },
        "rejected": { "type": "boolean" },
        "rejection_reasons": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "checkpoint_digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": [
        "schema",
        "manifest_digest",
        "checkpoint_digest",
        "immutable_digest",
        "mutable_digest",
        "trust",
        "compatible",
        "compatibility_digest"
      ],
      "properties": {
        "schema": { "const": "archie-checkpoint-compatibility/v1" },
        "manifest_digest": { "$ref": "#/$defs/digest" },
        "checkpoint_digest": { "$ref": "#/$defs/digest" },
        "immutable_digest": { "$ref": "#/$defs/digest" },
        "mutable_digest": { "$ref": "#/$defs/digest" },
        "trust": { "const": "trusted" },
        "compatible": { "const": true },
        "compatibility_digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/security-policy.schema.json",
  "title": "Maker security policy decision",
  "type": "object",
  "required": [
    "schema",
    "decision_id",
    "capability",
    "allowed",
    "reason",
    "rule_ids",
    "origin",
    "decided_at",
    "decision_digest"
  ],
  "properties": {
    "schema": { "const": "sideways-maker-security-decision/v1" },
    "decision_id": { "type": "string", "minLength": 1 },
    "capability": { "type": "string", "minLength": 1 },
    "allowed": { "type": "boolean" },
    "reason": { "type": "string" },
    "rule_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "origin": {
      "type": "object",
      "required": ["kind", "trust", "trust_level", "may_supply_instructions"],
      "properties": {
        "kind": { "type": "string" },
        "trust": { "enum": ["untrusted", "observed", "authenticated", "human", "control"] },
        "trust_level": { "type": "integer", "minimum": 0, "maximum": 4 },
        "may_supply_instructions": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "context": { "type": "object" },
    "evidence": { "type": "array" },
    "grant_id": { "type": ["string", "null"] },
    "decided_at": { "type": "string", "format": "date-time" },
    "decision_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}

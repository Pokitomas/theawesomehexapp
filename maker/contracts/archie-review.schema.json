{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/contracts/archie-review.schema.json",
  "title": "Archie review",
  "type": "object",
  "required": ["schema", "review_id", "workspace_id", "artifact_id", "reviewer_id", "decision", "reason", "submitted_at"],
  "properties": {
    "schema": { "const": "archie-review/v1" },
    "review_id": { "$ref": "#/$defs/id" },
    "workspace_id": { "$ref": "#/$defs/id" },
    "artifact_id": { "$ref": "#/$defs/id" },
    "reviewer_id": { "$ref": "#/$defs/id" },
    "decision": { "enum": ["approved", "changes_requested"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "submitted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,127}$" }
  },
  "additionalProperties": false
}

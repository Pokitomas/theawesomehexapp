{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archie.local/contracts/archie-metrics-receipt.schema.json",
  "title": "Archie independently recomputed metrics receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "candidate_id", "architecture_report_digest", "model_artifact_sha256", "runtime_sha256", "evidence_package_digest", "device_fingerprint", "sample_count", "independently_recomputed", "metrics", "receipt_digest"],
  "properties": {
    "schema": { "const": "archie-metrics-receipt/v1" },
    "candidate_id": { "$ref": "#/$defs/id" },
    "architecture_report_digest": { "$ref": "#/$defs/sha256" },
    "model_artifact_sha256": { "$ref": "#/$defs/sha256" },
    "runtime_sha256": { "$ref": "#/$defs/sha256" },
    "evidence_package_digest": { "$ref": "#/$defs/sha256" },
    "device_fingerprint": { "$ref": "#/$defs/sha256" },
    "sample_count": { "type": "integer", "minimum": 1 },
    "independently_recomputed": { "type": "boolean" },
    "metrics": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "number" } },
    "receipt_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@+\\-]{0,199}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

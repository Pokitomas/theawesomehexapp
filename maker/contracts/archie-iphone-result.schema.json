{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archie.local/contracts/archie-iphone-result.schema.json",
  "title": "Archie canonical physical iPhone result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "candidate_id", "architecture_report_digest", "model_artifact_sha256", "runtime_sha256", "evidence_package_digest", "metrics_receipt_digest", "device_fingerprint", "nonce", "authority_id", "binding_digest", "attestation", "decision", "result_digest"],
  "properties": {
    "schema": { "const": "archie-iphone-result/v1" },
    "candidate_id": { "$ref": "#/$defs/id" },
    "architecture_report_digest": { "$ref": "#/$defs/sha256" },
    "model_artifact_sha256": { "$ref": "#/$defs/sha256" },
    "runtime_sha256": { "$ref": "#/$defs/sha256" },
    "evidence_package_digest": { "$ref": "#/$defs/sha256" },
    "metrics_receipt_digest": { "$ref": "#/$defs/sha256" },
    "device_fingerprint": { "$ref": "#/$defs/sha256" },
    "nonce": { "type": "string", "minLength": 1, "maxLength": 500 },
    "authority_id": { "$ref": "#/$defs/id" },
    "binding_digest": { "$ref": "#/$defs/sha256" },
    "attestation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schema", "authority_id", "candidate_id", "package_digest", "binding_digest", "issued_at", "signature"],
      "properties": {
        "schema": { "const": "archie-iphone-measurement-attestation/v1" },
        "authority_id": { "$ref": "#/$defs/id" },
        "candidate_id": { "$ref": "#/$defs/id" },
        "package_digest": { "$ref": "#/$defs/sha256" },
        "binding_digest": { "$ref": "#/$defs/sha256" },
        "issued_at": { "type": "string", "format": "date-time" },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "decision": { "enum": ["admitted-canonical-physical-iphone-result", "rejected-canonical-physical-iphone-result"] },
    "result_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@+\\-]{0,199}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

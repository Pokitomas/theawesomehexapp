{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/archie-trajectory.schema.json",
  "title": "Archie provenance-bound training trajectory",
  "type": "object",
  "required": [
    "schema",
    "subject",
    "request",
    "provenance",
    "events",
    "verification",
    "outcome",
    "trajectory_digest"
  ],
  "properties": {
    "schema": { "const": "archie-trajectory/v1" },
    "subject": { "type": "string", "minLength": 1 },
    "request": { "type": "string", "minLength": 1 },
    "provenance": {
      "type": "object",
      "required": ["repository", "base_sha", "request_digest"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "branch": { "type": ["string", "null"] },
        "base_sha": { "$ref": "#/$defs/gitOid" },
        "head_sha": { "oneOf": [{ "$ref": "#/$defs/gitOid" }, { "type": "null" }] },
        "code_commit": { "oneOf": [{ "$ref": "#/$defs/gitOid" }, { "type": "null" }] },
        "request_digest": { "$ref": "#/$defs/digest" },
        "plan_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
        "patch_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
        "authority_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
        "environment_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
        "teacher": { "type": ["object", "null"] },
        "sources": { "type": "array" }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sequence", "type", "payload"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1 },
          "type": {
            "enum": [
              "request",
              "plan",
              "tool-call",
              "tool-result",
              "verification",
              "correction",
              "retry",
              "rollback",
              "user-intervention",
              "pause",
              "resume",
              "cancel",
              "outcome"
            ]
          },
          "at": { "type": ["string", "null"] },
          "payload": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["verifier", "status", "independent"],
        "properties": {
          "verifier": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "blocked", "skipped"] },
          "independent": { "type": "boolean" },
          "evidence_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
          "detail": { "type": "object" },
          "observed_at": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "outcome": {
      "type": "object",
      "required": ["status", "negative"],
      "properties": {
        "status": { "enum": ["completed", "failed", "rejected", "blocked", "cancelled", "partial"] },
        "summary": { "type": "string" },
        "negative": { "type": "boolean" },
        "delayed_signals": { "type": "object" },
        "observed_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "labels": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "parent_trajectory_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "trajectory_digest": { "$ref": "#/$defs/digest" },
    "recorded_at": { "type": ["string", "null"] }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gitOid": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/target-workspace.schema.json",
  "title": "Maker target workspace receipt",
  "type": "object",
  "required": [
    "schema",
    "workspace_id",
    "target_repository",
    "status",
    "receipt_digest"
  ],
  "properties": {
    "schema": { "const": "sideways-maker-target-workspace/v1" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "control_repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "target_repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "checkout": { "type": "string" },
    "base_revision": { "type": "string" },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "branch": { "type": "string" },
    "branch_head": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "status": {
      "enum": ["ready", "failed", "cleaned", "rolled_back"]
    },
    "authorization": {
      "type": "object",
      "required": ["repository", "permission", "required_permission", "allowed"],
      "properties": {
        "repository": { "type": "string" },
        "permission": { "enum": ["none", "read", "triage", "write", "maintain", "admin"] },
        "required_permission": { "enum": ["none", "read", "triage", "write", "maintain", "admin"] },
        "allowed": { "type": "boolean" },
        "default_branch": { "type": "string" },
        "archived": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "private": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "authority": {
      "type": "object",
      "properties": {
        "merge": { "const": "human" },
        "deploy": { "const": "human" },
        "repository_settings": { "const": "human" },
        "secrets": { "const": "none" }
      },
      "required": ["merge", "deploy", "repository_settings", "secrets"],
      "additionalProperties": false
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "transcript": { "type": "array", "items": { "type": "object" } },
    "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": true
}

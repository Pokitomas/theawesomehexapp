{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/archie-distilling-chamber.schema.json",
  "title": "Archie Linux recursive distilling chamber",
  "oneOf": [
    { "$ref": "#/$defs/event" },
    { "$ref": "#/$defs/checkpoint" }
  ],
  "$defs": {
    "event": {
      "type": "object",
      "required": ["schema", "run_id", "sequence", "observed_at", "event_id", "phase", "parent_event_id", "before", "after", "causal_edges"],
      "properties": {
        "schema": { "const": "archie-distilling-event/v1" },
        "run_id": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 },
        "observed_at": { "type": "string", "format": "date-time" },
        "event_id": { "type": "string", "minLength": 1 },
        "parent_event_id": { "type": ["string", "null"] },
        "episode_id": { "type": ["string", "null"] },
        "task_id": { "type": "string" },
        "phase": { "enum": ["observation", "inference", "intention", "execution", "verified_effect", "rejection", "blocker"] },
        "recursion_depth": { "type": "integer", "minimum": 0 },
        "before": {},
        "after": {},
        "causal_edges": { "type": "array", "items": { "type": "object" } },
        "metrics": { "type": "object" },
        "reason": { "type": "string" },
        "failure": { "type": "object" },
        "verdict": { "type": "object" },
        "result_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "state_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": true
    },
    "checkpoint": {
      "type": "object",
      "required": ["schema", "status", "lessons", "events", "digest"],
      "properties": {
        "schema": { "const": "archie-distilling-checkpoint/v1" },
        "status": { "type": "object" },
        "lessons": { "type": "array" },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}

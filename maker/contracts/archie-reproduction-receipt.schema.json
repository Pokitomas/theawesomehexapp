{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archie.local/contracts/archie-reproduction-receipt.schema.json",
  "title": "Archie clean reproduction receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "candidate_id", "architecture_report_digest", "model_artifact_sha256", "runtime_sha256", "environment_fingerprint", "reproduced", "checks", "receipt_digest"],
  "properties": {
    "schema": { "const": "archie-reproduction-receipt/v1" },
    "candidate_id": { "$ref": "#/$defs/id" },
    "architecture_report_digest": { "$ref": "#/$defs/sha256" },
    "model_artifact_sha256": { "$ref": "#/$defs/sha256" },
    "runtime_sha256": { "$ref": "#/$defs/sha256" },
    "environment_fingerprint": { "$ref": "#/$defs/sha256" },
    "reproduced": { "type": "boolean" },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["install", "offline_run", "benchmark", "upgrade", "rollback", "removal"],
      "properties": {
        "install": { "type": "boolean" },
        "offline_run": { "type": "boolean" },
        "benchmark": { "type": "boolean" },
        "upgrade": { "type": "boolean" },
        "rollback": { "type": "boolean" },
        "removal": { "type": "boolean" }
      }
    },
    "receipt_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@+\\-]{0,199}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

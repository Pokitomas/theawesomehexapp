{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theawesomehexapp.local/maker/contracts/archie-sync.schema.json",
  "title": "Archie encrypted synchronization envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "created_at", "algorithm", "key_id", "device_id", "namespace", "object_id", "object_kind",
    "generation", "immutable", "tombstone", "nonce", "aad_digest", "ciphertext", "ciphertext_bytes",
    "ciphertext_digest", "auth_tag", "envelope_digest"
  ],
  "properties": {
    "schema": { "const": "archie-encrypted-sync-envelope/v1" },
    "created_at": { "type": "string", "format": "date-time" },
    "algorithm": { "const": "aes-256-gcm" },
    "key_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "device_id": { "type": "string", "minLength": 1, "maxLength": 300 },
    "namespace": { "type": "string", "minLength": 1, "maxLength": 200 },
    "object_id": { "type": "string", "minLength": 1, "maxLength": 300 },
    "object_kind": { "type": "string", "minLength": 1, "maxLength": 100 },
    "generation": { "type": "integer", "minimum": 1 },
    "immutable": { "type": "boolean" },
    "tombstone": { "type": "boolean" },
    "nonce": { "type": "string", "pattern": "^[A-Za-z0-9_-]{16}$" },
    "aad_digest": { "$ref": "#/$defs/digest" },
    "ciphertext": { "type": "string", "pattern": "^[A-Za-z0-9_-]*$" },
    "ciphertext_bytes": { "type": "integer", "minimum": 0, "maximum": 67108864 },
    "ciphertext_digest": { "$ref": "#/$defs/digest" },
    "auth_tag": { "type": "string", "pattern": "^[A-Za-z0-9_-]{22}$" },
    "envelope_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.invalid/contracts/archie-research-status.schema.json",
  "title": "Archie research status v1",
  "type": "object",
  "required": ["schema", "campaign_id", "state", "campaign_digest", "allocation_digest", "discovery_lanes", "independent_evaluation_reserve", "workers_required"],
  "properties": {
    "schema": { "const": "archie-research-status/v1" },
    "campaign_id": { "type": "string", "minLength": 1 },
    "state": { "enum": ["awaiting-data", "materialized"] },
    "campaign_digest": { "$ref": "#/$defs/digest" },
    "prior_campaign_digest": { "$ref": "#/$defs/digest" },
    "allocation_digest": { "$ref": "#/$defs/digest" },
    "creation_receipt_digest": { "$ref": "#/$defs/digest" },
    "pack_digest": { "$ref": "#/$defs/digest" },
    "split_digest": { "$ref": "#/$defs/digest" },
    "materialization_digest": { "$ref": "#/$defs/digest" },
    "discovery_lanes": { "const": 12 },
    "independent_evaluation_reserve": { "const": 20 },
    "workers_required": { "const": false },
    "hidden_scores_exposed": { "const": false }
  },
  "$defs": { "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archie-candidate-move/v1",
  "title": "Archie open candidate move",
  "type": "object",
  "required": ["schema", "candidate_id", "kind", "effect_class", "sequence"],
  "properties": {
    "schema": {"const": "archie-candidate-move/v1"},
    "candidate_id": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1, "description": "Open vocabulary. Cognition is not restricted to a fixed task or operator taxonomy."},
    "effect_class": {"enum": ["internal", "external", "durable-training", "no-op"]},
    "description": {"type": "string"},
    "proposal": {},
    "expected_evidence": {},
    "constraints": {},
    "provenance": {},
    "sequence": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}

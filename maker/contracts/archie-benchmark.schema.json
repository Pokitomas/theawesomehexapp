{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theawesomehexapp.local/maker/contracts/archie-benchmark.schema.json",
  "title": "Archie matched-task equivalence benchmark contracts",
  "oneOf": [
    { "$ref": "#/$defs/suite" },
    { "$ref": "#/$defs/candidateResults" },
    { "$ref": "#/$defs/report" },
    { "$ref": "#/$defs/promptPack" }
  ],
  "$defs": {
    "toolAction": {
      "type": "object",
      "required": ["tool", "action"],
      "properties": {
        "tool": { "type": "string" },
        "action": { "type": "string" },
        "ok": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "episode": {
      "type": "object",
      "required": ["id", "class", "instruction", "expected_state", "reference_actions"],
      "properties": {
        "id": { "type": "string" },
        "class": { "type": "string" },
        "instruction": { "type": "string" },
        "expected_state": { "enum": ["local", "teacher", "reject"] },
        "reference_actions": { "type": "array", "items": { "type": "string", "pattern": "^[^:]+:[^:]+$" } },
        "session": { "type": "string" },
        "adaptation_group": { "type": "string" },
        "teacher_fixture": { "type": "object" }
      },
      "additionalProperties": true
    },
    "suite": {
      "type": "object",
      "required": ["schema", "suite_id", "training", "episodes"],
      "properties": {
        "schema": { "const": "archie-equivalence-suite/v1" },
        "suite_id": { "type": "string" },
        "training": { "type": "array", "items": { "type": "object" } },
        "episodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/episode" } }
      },
      "additionalProperties": true
    },
    "candidateResult": {
      "type": "object",
      "required": ["episode_id", "state"],
      "properties": {
        "episode_id": { "type": "string" },
        "state": { "type": "string" },
        "plan": {},
        "tool_trace": { "type": "array", "items": { "$ref": "#/$defs/toolAction" } },
        "latency_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "candidateResults": {
      "type": "object",
      "required": ["schema", "candidate_id", "candidate_role", "results"],
      "properties": {
        "schema": { "const": "archie-candidate-results/v1" },
        "candidate_id": { "type": "string" },
        "candidate_role": { "enum": ["substitution-system", "teacher-model"] },
        "results": { "type": "array", "items": { "$ref": "#/$defs/candidateResult" } }
      },
      "additionalProperties": false
    },
    "report": {
      "type": "object",
      "required": ["schema", "suite_id", "candidate_id", "candidate_role", "metrics", "equivalence_score", "episodes", "report_digest"],
      "properties": {
        "schema": { "const": "archie-equivalence-report/v1" },
        "suite_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "candidate_role": { "enum": ["substitution-system", "teacher-model"] },
        "metrics": { "type": "object" },
        "equivalence_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "episodes": { "type": "array" },
        "report_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": true
    },
    "promptPack": {
      "type": "object",
      "required": ["schema", "suite_id", "candidate_role", "instruction", "output_contract", "tools", "episodes", "prompt_pack_digest"],
      "properties": {
        "schema": { "const": "archie-benchmark-prompt-pack/v1" },
        "suite_id": { "type": "string" },
        "candidate_role": { "const": "teacher-model" },
        "instruction": { "type": "string" },
        "output_contract": { "type": "object" },
        "tools": { "type": "array" },
        "episodes": { "type": "array" },
        "prompt_pack_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}

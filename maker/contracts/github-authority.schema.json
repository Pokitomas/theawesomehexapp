{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/github-authority.schema.json",
  "title": "Maker GitHub authority packet",
  "type": "object",
  "required": [
    "schema",
    "action",
    "target",
    "issued_by",
    "nonce",
    "expires_at",
    "human_approved",
    "packet_digest"
  ],
  "properties": {
    "schema": { "const": "sideways-maker-github-authority/v1" },
    "action": { "type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z][a-z0-9-]*$" },
    "target": { "type": "string", "minLength": 1, "maxLength": 300 },
    "issued_by": { "type": "string", "minLength": 1, "maxLength": 300 },
    "nonce": { "type": "string", "minLength": 1, "maxLength": 300 },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "human_approved": { "const": true },
    "confirmation": { "type": ["string", "null"] },
    "constraints": { "type": "object" },
    "packet_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}

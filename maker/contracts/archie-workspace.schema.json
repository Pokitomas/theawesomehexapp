{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/contracts/archie-workspace.schema.json",
  "title": "Archie workspace",
  "type": "object",
  "required": ["schema", "workspace_id", "title", "visibility", "owner_id", "created_at", "claim_boundary"],
  "properties": {
    "schema": { "const": "archie-workspace/v1" },
    "workspace_id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "visibility": { "enum": ["public", "private", "locally_sealed"] },
    "owner_id": { "$ref": "#/$defs/id" },
    "created_at": { "type": "string", "format": "date-time" },
    "claim_boundary": { "type": "string", "minLength": 40 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,127}$" }
  },
  "additionalProperties": false
}

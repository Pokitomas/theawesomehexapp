{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archie.local/contracts/archie-candidate-completion-decision.schema.json",
  "title": "Archie candidate completion decision",
  "type": "object",
  "required": ["schema", "candidate_id", "architecture_id", "complete", "selected_candidate_id", "blockers", "verified_files", "verified_internal_digests", "authority", "claim_boundary", "decision_digest"],
  "properties": {
    "schema": { "const": "archie-candidate-completion-decision/v1" },
    "candidate_id": { "type": "string" },
    "architecture_id": { "type": "string" },
    "complete": { "type": "boolean" },
    "selected_candidate_id": { "type": ["string", "null"] },
    "blockers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "verified_files": { "type": "object" },
    "verified_internal_digests": { "type": "object" },
    "authority": { "type": "object" },
    "claim_boundary": { "type": "string" },
    "decision_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

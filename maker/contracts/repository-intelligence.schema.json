{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/maker/contracts/repository-intelligence.schema.json",
  "title": "Maker exact-revision repository map",
  "type": "object",
  "required": [
    "schema",
    "repository",
    "base_sha",
    "branch",
    "checkout_dirty",
    "limits",
    "observed",
    "languages",
    "manifests",
    "workflows",
    "files",
    "tests",
    "commands",
    "hotspots",
    "secret_findings",
    "generated_at",
    "map_digest"
  ],
  "properties": {
    "schema": { "const": "sideways-maker-repository-map/v1" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "branch": { "type": "string" },
    "checkout_dirty": { "type": "boolean" },
    "dirty_status_digest": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "limits": { "type": "object" },
    "observed": {
      "type": "object",
      "required": ["tracked_candidates", "files", "bytes", "truncated"],
      "properties": {
        "tracked_candidates": { "type": "integer", "minimum": 0 },
        "files": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "languages": { "type": "array", "items": { "type": "object" } },
    "manifests": { "type": "array", "items": { "type": "object" } },
    "workflows": { "type": "array", "items": { "type": "object" } },
    "codeowners": { "type": "array", "items": { "type": "object" } },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path", "language", "bytes", "test", "generated", "vendor", "documentation",
          "secret_path", "secret_finding_count", "owners", "imports", "reverse_imports", "symbols", "hotspot_score"
        ],
        "properties": {
          "path": { "type": "string" },
          "language": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "lines": { "type": ["integer", "null"] },
          "content_digest": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
          "test": { "type": "boolean" },
          "generated": { "type": "boolean" },
          "vendor": { "type": "boolean" },
          "documentation": { "type": "boolean" },
          "secret_path": { "type": "boolean" },
          "secret_finding_count": { "type": "integer", "minimum": 0 },
          "owners": { "type": "array", "items": { "type": "string" } },
          "imports": { "type": "array", "items": { "type": "object" } },
          "reverse_imports": { "type": "array", "items": { "type": "string" } },
          "symbols": { "type": "array", "items": { "type": "object" } },
          "hotspot_score": { "type": "integer", "minimum": 0, "maximum": 100 }
        },
        "additionalProperties": true
      }
    },
    "tests": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "object" } },
    "hotspots": { "type": "array", "items": { "type": "object" } },
    "secret_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "id", "fingerprint", "length"],
        "properties": {
          "path": { "type": "string" },
          "id": { "type": "string" },
          "fingerprint": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
          "length": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "map_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokitomas.github.io/theawesomehexapp/contracts/archie-objective.schema.json",
  "title": "Archie objective",
  "type": "object",
  "required": ["schema", "objective_id", "workspace_id", "statement", "protected_reality", "proof_of_done", "status", "created_by", "created_at", "objective_digest"],
  "properties": {
    "schema": { "const": "archie-objective/v1" },
    "objective_id": { "$ref": "#/$defs/id" },
    "workspace_id": { "$ref": "#/$defs/id" },
    "statement": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "protected_reality": { "type": ["string", "null"], "maxLength": 20000 },
    "proof_of_done": { "type": ["string", "null"], "maxLength": 20000 },
    "status": { "enum": ["active", "completed", "cancelled"] },
    "created_by": { "$ref": "#/$defs/id" },
    "created_at": { "type": "string", "format": "date-time" },
    "objective_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}

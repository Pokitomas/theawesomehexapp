{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.invalid/contracts/archie-student-training-receipt.schema.json",
  "title": "Archie student training receipt v1",
  "type": "object",
  "required": [
    "schema",
    "observed_at",
    "duration_ms",
    "status",
    "pack_digest",
    "training_data_digest",
    "heldout_data_digest",
    "training_config_digest",
    "optimizer_digest",
    "seed",
    "teacher_ids",
    "base_model",
    "command",
    "result",
    "claim_boundary",
    "receipt_digest"
  ],
  "properties": {
    "schema": {
      "const": "archie-student-training-receipt/v1"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "number",
      "minimum": 0
    },
    "status": {
      "enum": [
        "completed",
        "failed"
      ]
    },
    "pack_digest": {
      "$ref": "#/$defs/digest"
    },
    "training_data_digest": {
      "$ref": "#/$defs/digest"
    },
    "heldout_data_digest": {
      "$ref": "#/$defs/digest"
    },
    "training_config_digest": {
      "$ref": "#/$defs/digest"
    },
    "optimizer_digest": {
      "$ref": "#/$defs/digest"
    },
    "evaluation_receipt_digest": {
      "oneOf": [
        {
          "$ref": "#/$defs/digest"
        },
        {
          "type": "null"
        }
      ]
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "teacher_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "base_model": {
      "type": "object",
      "required": [
        "id",
        "digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "required": [
        "program",
        "args",
        "command_digest"
      ],
      "properties": {
        "program": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "ok",
        "exit_code",
        "stdout",
        "stderr"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "exit_code": {
          "type": "integer"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "relative_path",
            "bytes",
            "sha256"
          ],
          "properties": {
            "relative_path": {
              "type": "string",
              "minLength": 1
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            },
            "sha256": {
              "$ref": "#/$defs/digest"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "metrics": {
      "oneOf": [
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    },
    "receipt_digest": {
      "$ref": "#/$defs/digest"
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}

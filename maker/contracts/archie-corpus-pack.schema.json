{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sideways.local/contracts/archie-corpus-pack.schema.json",
  "title": "Archie portable corpus pack",
  "oneOf": [
    { "$ref": "#/$defs/pack" },
    { "$ref": "#/$defs/receipt" }
  ],
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_entries", "max_file_bytes", "max_total_bytes"],
      "properties": {
        "max_entries": { "type": "integer", "minimum": 1 },
        "max_file_bytes": { "type": "integer", "minimum": 1 },
        "max_total_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256", "encoding", "content"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4000, "not": { "pattern": "(^/|(^|/)\\.\\.(/|$)|^[A-Za-z]:)" } },
        "bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/digest" },
        "encoding": { "const": "base64" },
        "content": { "type": "string" }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "created_at", "source", "limits", "entries", "pack_digest"],
      "properties": {
        "schema": { "const": "archie-corpus-pack/v1" },
        "created_at": { "type": "string", "format": "date-time" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership", "format", "entry_count", "total_bytes"],
          "properties": {
            "ownership": { "const": "personal" },
            "format": { "const": "archie-linux-corpus" },
            "entry_count": { "type": "integer", "minimum": 0 },
            "total_bytes": { "type": "integer", "minimum": 0 }
          }
        },
        "limits": { "$ref": "#/$defs/limits" },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/entry" } },
        "pack_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "receipt": {
      "type": "object",
      "required": ["schema", "operation", "status", "pack_digest"],
      "properties": {
        "schema": { "const": "archie-corpus-pack-receipt/v1" },
        "operation": { "enum": ["export", "inspect", "import"] },
        "status": { "enum": ["created", "valid", "restored", "failed"] },
        "pack_digest": { "$ref": "#/$defs/digest" },
        "entry_count": { "type": "integer", "minimum": 0 },
        "total_bytes": { "type": "integer", "minimum": 0 },
        "rollback": { "enum": ["not_required", "complete", "failed"] }
      }
    }
  }
}

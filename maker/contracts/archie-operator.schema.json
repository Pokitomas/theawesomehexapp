{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theawesomehexapp.local/maker/contracts/archie-operator.schema.json",
  "title": "Archie phone operator receipt and command packet",
  "oneOf": [
    {
      "$ref": "#/$defs/receipt"
    },
    {
      "$ref": "#/$defs/command"
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "source",
        "namespace",
        "observed_at",
        "expires_at",
        "payload",
        "payload_digest",
        "receipt_digest"
      ],
      "properties": {
        "schema": {
          "const": "archie-operator-runtime-receipt/v1"
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "namespace": {
          "const": "maker:archie"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "maxProperties": 64
        },
        "payload_digest": {
          "$ref": "#/$defs/digest"
        },
        "receipt_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "namespace",
        "created_at",
        "operation",
        "payload",
        "execution_claimed",
        "requires_authenticated_runtime",
        "requires_explicit_authority",
        "command_digest"
      ],
      "properties": {
        "schema": {
          "const": "archie-operator-command/v1"
        },
        "namespace": {
          "const": "maker:archie"
        },
        "operation": {
          "enum": [
            "export_pack",
            "import_pack",
            "sync",
            "run_task",
            "retrain",
            "refresh_receipt"
          ]
        },
        "execution_claimed": {
          "const": false
        },
        "requires_authenticated_runtime": {
          "const": true
        },
        "requires_explicit_authority": {
          "const": true
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "maxProperties": 64
        }
      }
    }
  }
}

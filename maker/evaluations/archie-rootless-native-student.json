{
  "schema": "archie-rootless-native-student/v1",
  "status": "research-only-not-admitted",
  "starting_weights": {
    "kind": "random-initialization",
    "pretrained_weights_allowed": false,
    "adapters_allowed": false,
    "generation_zero_seed_required": true
  },
  "teachers": {
    "allowed": [
      "authorized-human",
      "authorized-assistant",
      "bounded-agent-subprocess"
    ],
    "weights_transferred": false,
    "verified_episode_required": true,
    "lineage_required": true
  },
  "student": {
    "kind": "engineered-rootless-recurrent-or-state-space-student",
    "candidate_components": [
      "intent-and-observation-encoder",
      "persistent-workspace",
      "action-and-tool-heads",
      "artifact-decoder",
      "verifier-value-head",
      "uncertainty-and-stop-head"
    ],
    "runtime_tools_allowed": true,
    "runtime_memory_allowed": true,
    "runtime_retrieval_allowed": true,
    "runtime_compilers_allowed": true,
    "runtime_actuators_allowed": true,
    "hidden_foundation_model_as_tool_allowed": false
  },
  "training": {
    "device": "local-cuda-alienware",
    "relay": "sealed-outbound-polling-self-state-relay",
    "complete_checkpoint_resume_required": true,
    "optimizer_continuity_required": true,
    "hosted_finetuning_api_required": false,
    "external_automl_required": false,
    "external_agent_framework_required": false,
    "manual_cuda_operation_between_rounds_required": false,
    "repository_native_training_code_required": true,
    "losses": [
      "action-or-artifact",
      "state-delta",
      "verifier-value",
      "failed-vs-repaired-branch",
      "tool-choice",
      "memory-consistency",
      "calibrated-stop",
      "compute-budget"
    ]
  },
  "deployment_forms_allowed": [
    "artifact-ir-and-compiler",
    "archie-tool-selection-and-verified-execution",
    "bounded-direct-action",
    "memory-tool-artifact-loop"
  ],
  "required_evidence": [
    "capsule-digest",
    "parent-checkpoint-digest",
    "generation-zero-random-init-proof",
    "no-pretrained-tensor-load-proof",
    "teacher-episode-lineage",
    "cuda-device-identity",
    "gpu-seconds",
    "changed-student-tensor-digests",
    "optimizer-resume-continuity",
    "frozen-held-out-results",
    "selected-architecture-tool-action-artifact-metrics",
    "quantized-retention",
    "signed-receipt"
  ],
  "promotion": {
    "automatic": false,
    "requires_independent_reproduction": true,
    "requires_human_admission": true
  },
  "documentation": "docs/archie-rootless-native-student.md"
}

{
  "schema": "archie-launch-target/v2",
  "id": "archie-maximal-general-builder-frontier",
  "claim_boundary": "Founder launch-selection law and evidence contract, not a claim that any current checkpoint or device profile satisfies it.",
  "intelligence_target": {
    "domains": [
      "product-creation",
      "software",
      "research",
      "open-world-tool-use",
      "planning",
      "artifact-production",
      "creative-work",
      "safety-and-authority"
    ],
    "minimum_metrics": {
      "cross_domain_completion_rate": 0.8,
      "unfamiliar_product_completion_rate": 0.75,
      "failure_repair_rate": 0.8,
      "calibrated_abstention_rate": 0.9,
      "false_completion_rate_max": 0.005,
      "terminal_evidence_rate": 0.98,
      "clean_environment_reproduction_rate": 0.95,
      "authority_compliance_rate": 1
    },
    "requirements": [
      "derive-explicit-end-state",
      "discover-user-need-and-product-model",
      "complete-unfamiliar-product-builds",
      "pursue-unmet-requirements-within-budget",
      "repair-after-verified-failure",
      "distinguish-success-partial-blocked-impossible-unsafe-and-exhausted",
      "generalize-across-unfamiliar-domains",
      "preserve-authority-and-uncertainty",
      "produce-proof-carrying-terminal-artifacts",
      "reproduce-delivery-on-clean-environment"
    ]
  },
  "human_outcomes": [
    {
      "id": "objective-completion",
      "floor": 0.7,
      "statement": "The admitted product profile completes demanding end-to-end objectives rather than merely producing persuasive conversation."
    },
    {
      "id": "interruptibility",
      "floor": 0.7,
      "statement": "The user can direct, interrupt, inspect, and regain control through whatever interaction form the admitted profile can truthfully sustain."
    },
    {
      "id": "continuity",
      "floor": 0.6,
      "statement": "Authorized work preserves enough state and resumability for the declared environment without pretending unsupported background presence."
    },
    {
      "id": "inspectability",
      "floor": 0.9,
      "statement": "Plans, permissions, evidence, artifacts, uncertainty, and unfinished obligations remain inspectable at the precision required by the work."
    },
    {
      "id": "user-control",
      "floor": 0.95,
      "statement": "Observation, notification, tool use, and effects remain bounded by explicit user authority and revocation."
    },
    {
      "id": "privacy",
      "floor": 0.8,
      "statement": "The profile exposes its sensing, retention, network, and local-processing boundaries and does not manufacture ambient access."
    }
  ],
  "profile_search": {
    "required_axes": [
      "intelligence",
      "interaction-bandwidth",
      "latency",
      "continuity",
      "availability",
      "proactivity",
      "modality",
      "device-reach",
      "locality",
      "authority",
      "privacy",
      "platform-constraints",
      "resource-envelope"
    ],
    "dimensions": [
      {
        "id": "end_to_end_completion_rate",
        "direction": "maximize",
        "range": "unit_interval",
        "floor": 0.7
      },
      {
        "id": "interaction_bandwidth_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "continuity_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "availability_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "proactivity_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "modality_breadth_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "device_reach_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "user_control_score",
        "direction": "maximize",
        "range": "unit_interval",
        "floor": 0.95
      },
      {
        "id": "privacy_score",
        "direction": "maximize",
        "range": "unit_interval",
        "floor": 0.8
      },
      {
        "id": "offline_capability_score",
        "direction": "maximize",
        "range": "unit_interval"
      },
      {
        "id": "p95_interaction_latency_ms",
        "direction": "minimize",
        "range": "nonnegative"
      },
      {
        "id": "peak_memory_mb",
        "direction": "minimize",
        "range": "nonnegative"
      },
      {
        "id": "sustained_energy_watts",
        "direction": "minimize",
        "range": "nonnegative"
      },
      {
        "id": "network_dependency_score",
        "direction": "minimize",
        "range": "unit_interval"
      },
      {
        "id": "interruption_burden_score",
        "direction": "minimize",
        "range": "unit_interval"
      }
    ],
    "require_complete_search_receipt": true,
    "require_nondominated_launch_set": true,
    "allow_adaptive_multi_profile_launch": true,
    "selected_default_may_be_null": true
  },
  "launch_policy": {
    "joint_intelligence_and_embodiment_admission": true,
    "single_canonical_interface": false,
    "chat_window_is_architecture": false,
    "voice_is_architecture": false,
    "always_on_daemon_is_architecture": false,
    "cli_is_consumer_identity": false,
    "dominated_default_may_launch": false,
    "hidden_nondominated_fallback_may_launch": false,
    "unsupported_capability_may_be_claimed": false,
    "shell_without_brain_may_launch": false,
    "brain_without_admitted_profile_may_launch": false,
    "maximal_first_release": true
  }
}

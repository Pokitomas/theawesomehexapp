{
  "node_id": "alienware-1",
  "repo": "Pokitomas/theawesomehexapp",
  "workspace": "~/archie-continuum",
  "repo_cache": "~/archie-continuum/repo-cache",
  "poll": {
    "workflow": "archie-continuum-capsule.yml",
    "branch": "agent/archie-continuum-local-compute",
    "limit": 20
  },
  "security": {
    "allowed_repos": [
      "Pokitomas/theawesomehexapp"
    ],
    "allowed_tasks": [
      "terminal-efficiency-v3"
    ],
    "hmac_env": "ARCHIE_CONTINUUM_HMAC_KEY",
    "require_cuda": true
  },
  "tasks": {
    "terminal-efficiency-v3": {
      "require_cuda": true,
      "cwd": "foundry/archie-protocol/latent_world_benchmark",
      "env": {
        "PYTHONPATH": ".",
        "PYTHONUNBUFFERED": "1"
      },
      "argv": [
        "python3",
        "{worktree}/compute/continuum/terminal_cuda.py",
        "--campaign-root",
        "{campaign_root}",
        "--output",
        "{output_dir}",
        "--scale",
        "{scale}",
        "--seed",
        "{seed}",
        "--rung1",
        "{rung1}",
        "--rung2",
        "{rung2}",
        "--rung3",
        "{rung3}",
        "--batch-size",
        "{batch_size}",
        "--eval-batch-size",
        "{eval_batch_size}",
        "--threads",
        "{threads}",
        "--device",
        "{device}"
      ],
      "defaults": {
        "source_run_id": 29834460894,
        "source_artifact": "archie-causal-mechanism-maximal-29834460894",
        "scale": "base",
        "seed": 30260721,
        "rung1": 192,
        "rung2": 640,
        "rung3": 1536,
        "batch_size": 64,
        "eval_batch_size": 32,
        "threads": 4,
        "device": "cuda",
        "restart": false
      },
      "allowed_args": {
        "source_run_id": {
          "type": "int",
          "min": 1,
          "max": 99999999999
        },
        "source_artifact": "id",
        "scale": [
          "base",
          "temporal_horizon",
          "object_cardinality"
        ],
        "seed": {
          "type": "int",
          "min": 0,
          "max": 2147483647
        },
        "rung1": {
          "type": "int",
          "min": 1,
          "max": 100000
        },
        "rung2": {
          "type": "int",
          "min": 2,
          "max": 100000
        },
        "rung3": {
          "type": "int",
          "min": 3,
          "max": 100000
        },
        "batch_size": {
          "type": "int",
          "min": 1,
          "max": 4096
        },
        "eval_batch_size": {
          "type": "int",
          "min": 1,
          "max": 4096
        },
        "threads": {
          "type": "int",
          "min": 1,
          "max": 128
        },
        "device": [
          "cuda",
          "cpu",
          "auto"
        ],
        "restart": "bool"
      },
      "study_patterns": [
        "rung-*.json"
      ],
      "study_interval_seconds": 20,
      "result_patterns": [
        "**/*.json",
        "**/*.pt"
      ],
      "handoff_state_patterns": [
        "terminal-efficiency-report.json",
        "rung-*.json"
      ],
      "strictly_increasing_args": [
        "rung1",
        "rung2",
        "rung3"
      ]
    }
  },
  "providers": [],
  "publish": {
    "mode": "release",
    "draft": true,
    "tag_prefix": "archie-compute"
  }
}

coordination_alerts:
  - id: redundant-add-route
    severity: active
    finding: Re-routing an already-visible ADD view can detach the consumer workbench during import.
    resolution: Import in place; only route when opening the importer from another view.
  - id: exposed-user-token
    severity: security
    finding: A GitHub personal access token was pasted into chat.
    resolution: Do not use or store it; user must revoke it after completion.


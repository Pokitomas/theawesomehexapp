{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theawesomehexapp.local/schemas/capability-candidate-v1.json",
  "title": "Capability candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repository",
    "commit_sha",
    "evidence_paths",
    "license",
    "capability",
    "use_class",
    "decision",
    "promotion"
  ],
  "properties": {
    "schema": {"const": "archie-capability-candidate/v1"},
    "repository": {"type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "evidence_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared_id", "license_file_sha256", "review_state"],
      "properties": {
        "declared_id": {"type": "string", "minLength": 1},
        "license_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "review_state": {"enum": ["unreviewed", "compatible", "idea-only", "rejected"]},
        "obligations": {"type": "array", "items": {"type": "string"}}
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "claim", "inputs", "outputs", "acceptance_tests"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "claim": {"type": "string", "minLength": 1},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "outputs": {"type": "array", "items": {"type": "string"}},
        "invariants": {"type": "array", "items": {"type": "string"}},
        "failure_modes": {"type": "array", "items": {"type": "string"}},
        "acceptance_tests": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "use_class": {"enum": ["metadata-only", "idea-only", "spec-and-tests", "licensed-source", "rejected"]},
    "derived_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reviewer": {"type": "string"},
    "decision": {"enum": ["pending", "approved", "rejected"]},
    "promotion": {"const": "research-only-not-admitted"}
  }
}
